generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  applications Application[] @relation("UserApplications")
  createdJobs  Job[]         @relation("UserJobs")
  partner      Partner?
}

model Job {
  id                String        @id @default(uuid())
  title             String
  description       String?
  createdAt         DateTime      @default(now())
  createdById       String
  closureDate       DateTime?
  companyName       String?
  department        String?
  education         String?
  jrCode            String?       @unique
  location          String?
  maxExperience     Int?
  minExperience     Int?
  openings          Int?
  requestDate       DateTime?
  salaryMax         Int?
  salaryMin         Int?
  skills            String?
  skillsArray  String[]
  embedding   Json?
  applicationsCount Int           @default(0)
  clientContact     String?
  clientEmail       String?
  clientName        String?
  updatedAt         DateTime      @updatedAt
  status            JobStatus     @default(OPEN)
  extraData         Json?
  jd                String?
  source            JobSource     @default(MANUAL)
  applications      Application[]
  createdBy         User          @relation("UserJobs", fields: [createdById], references: [id])

  @@index([status])
}

model UploadJob {
  id        String   @id @default(cuid())
  status    String
  total     Int
  processed Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  created   Int      @default(0)
  duplicate Int      @default(0)
  error     Int      @default(0)
  results   Json?
  skipped   Int      @default(0)
}

model Candidate {
  id                   String          @id @default(uuid())
  /// /////////////////////////////////////////////////////////
  /// BASIC
  /// /////////////////////////////////////////////////////////
  name                 String
  email                String?
  phone                String?
  /// /////////////////////////////////////////////////////////
  createdAt            DateTime        @default(now())
  createdByUserId      String?
  createdByPartnerId   String?
  currentCompany       String?
  currentDesignation   String?
  /// /////////////////////////////////////////////////////////
  /// LOCATION
  /// /////////////////////////////////////////////////////////
  currentLocation      String?
  currentSalary        Float?
  department           String?
  expectedSalary       Float?
  /// /////////////////////////////////////////////////////////
  /// EDUCATION
  /// /////////////////////////////////////////////////////////
  highestQualification String?
  hometown             String?
  industry             String?
  noticePeriodDays     Int?
  pincode              String?
  preferredLocations   String?
  skills               String?
  skillsArray  String[]
  embedding   Json?
  /// /////////////////////////////////////////////////////////
  /// PROFESSIONAL
  /// /////////////////////////////////////////////////////////
  totalExperience      Float?
  updatedAt            DateTime        @updatedAt
  resumeText           String?
  /// /////////////////////////////////////////////////////////
  /// RESUME
  /// /////////////////////////////////////////////////////////
  resumeUrl            String?
  /// /////////////////////////////////////////////////////////
  /// SOURCE + CREATOR TRACKING
  /// /////////////////////////////////////////////////////////
  source               CandidateSource @default(DIRECT_APPLY)
  resumeHash           String?         @unique
  applications         Application[]

  @@index([email])
  @@index([phone])
}

model Application {
  id                   String                  @id @default(uuid())
  createdAt            DateTime                @default(now())
  jobId                String
  candidateId          String
  appliedByUserId      String?
  appliedByPartnerId   String?
  contactedAt          DateTime?
  finalStatus          ApplicationFinalStatus?
  hiredAt              DateTime?
  interviewCompletedAt DateTime?
  interviewScheduledAt DateTime?
  notes                String?
  offerAcceptedAt      DateTime?
  offerRejectedAt      DateTime?
  offerSentAt          DateTime?
  pipelineStage        ApplicationStage        @default(APPLIED)
  rejectedAt           DateTime?
  rejectionReason      String?
  source               String?
  updatedAt            DateTime                @updatedAt
  appliedByPartner     Partner?                @relation("PartnerApplications", fields: [appliedByPartnerId], references: [id])
  appliedByUser        User?                   @relation("UserApplications", fields: [appliedByUserId], references: [id])
  candidate            Candidate               @relation(fields: [candidateId], references: [id])
  job                  Job                     @relation(fields: [jobId], references: [id])

  @@unique([candidateId, jobId])
  @@index([jobId])
  @@index([candidateId])
  @@index([pipelineStage])
  @@index([finalStatus])
  @@index([appliedByUserId])
  @@index([appliedByPartnerId])
}

model Partner {
  id                String        @id @default(uuid())
  userId            String        @unique
  createdAt         DateTime      @default(now())
  status            PartnerStatus @default(PENDING)
  address           String
  contactNumber     String
  establishmentDate DateTime
  gstNumber         String
  msmeRegistered    Boolean       @default(false)
  officialEmail     String
  organisationName  String
  ownerName         String
  panNumber         String
  applications      Application[] @relation("PartnerApplications")
  user              User          @relation(fields: [userId], references: [id])
}

enum JobSource {
  MANUAL
  CSV_UPLOAD
  JD_UPLOAD
}

enum JobStatus {
  OPEN
  CLOSED
  ON_HOLD
  CANCELLED
}

enum CandidateSource {
  DIRECT_APPLY
  PARTNER_UPLOAD
  ADMIN_RESUME_UPLOAD
  ADMIN_CSV_UPLOAD
}

enum ApplicationStage {
  APPLIED
  SCREENING
  CONTACTED
  DOCUMENT_REQUESTED
  DOCUMENT_RECEIVED
  SUBMITTED_TO_CLIENT
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  SHORTLISTED
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  HIRED
  REJECTED
}

enum ApplicationFinalStatus {
  HIRED
  REJECTED
  WITHDRAWN
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  PARTNER
  ADMIN
  RECRUITER
}
